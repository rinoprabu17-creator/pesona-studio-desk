# Environment template for Pesona Studio Desk.
# For laptop development, copy .env.local.example to .env.local.

# App
APP_NAME=Pesona Studio Desk
APP_ENV=development
APP_URL=http://localhost:3000
APP_PORT=3000
WEB_APP_EXPOSED_PORT=3000
APP_STORAGE_DIR=/app/storage
PSD_ADMIN_USER=change_me_admin_user
PSD_ADMIN_PASSWORD=change_me_admin_password
OPERATIONAL_FOOTAGE_SOURCE_DIR=/app/storage/footage

# Local-first profile documentation only; not enforced by runtime in Phase 2A.6B.
# Default runtime is the office server. VPS and GPU are not initial requirements.
# Google Drive is backup/sharing only, not primary working storage.
DEPLOYMENT_PROFILE=local_office
SERVER_OPERATION_START=08:00
SERVER_OPERATION_END=20:00
CONTENT_LAST_POST_TIME=19:00
CONTENT_PRIME_TIME=20:00
MANYCHAT_ENABLED=false
PLATFORM_LEAD_BRIDGE=meta_business_suite
WHATSAPP_FRONTLINER=whatsapp_business_ai
DEFAULT_AI_MODEL=gpt-5.4-mini
AI_MONTHLY_BUDGET_USD=10

# PostgreSQL
POSTGRES_DB=pesona_studio
POSTGRES_USER=pesona
POSTGRES_PASSWORD=change_me_database_password
POSTGRES_EXPOSED_PORT=5432
DATABASE_URL=postgresql://pesona:change_me_database_password@postgres:5432/pesona_studio
TEST_DATABASE_URL=postgresql://pesona:change_me_database_password@postgres:5432/pesona_studio_test

# Redis
REDIS_EXPOSED_PORT=6379
REDIS_URL=redis://redis:6379

# n8n
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EXPOSED_PORT=5678
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password
N8N_ENCRYPTION_KEY=change_me_32_chars_minimum_secret
GENERIC_TIMEZONE=Asia/Jakarta

# Internal placeholders
INTERNAL_API_TOKEN=change_me_internal_token
VIDEO_WORKER_POLL_INTERVAL_MS=15000
MOCKUP_WORKER_POLL_INTERVAL_MS=15000

# Campaign Planner. Default is fake/local and must not call paid APIs.
# Use docker-compose.openai.yml plus explicit secrets only when owner approves OpenAI use.
CAMPAIGN_PLANNER_PROVIDER=fake
CAMPAIGN_PLANNER_OPENAI_ENABLED=false
CAMPAIGN_PLANNER_PROMPT_VERSION=campaign-planner-v1
CAMPAIGN_PLANNER_FAKE_MODE=valid
CAMPAIGN_PLANNER_POLL_MS=2000
CAMPAIGN_PLANNER_LEASE_SECONDS=60
CAMPAIGN_PLANNER_MAX_ATTEMPTS=3
CAMPAIGN_PLANNER_BATCH_SIZE=5
OPENAI_MODEL=
OPENAI_TIMEOUT_MS=120000
OPENAI_MAX_OUTPUT_TOKENS=5000
